QMainWindow {
    background:#000000;
}

QWidget {
    background:#000000;
    color:white;
    font-family:'Segoe UI';
    font-size:10pt;
}

QFrame#cardLeft, QFrame#cardRight {
    background:#16181C;
    border:1px solid #2F3336;
    border-radius:18px;
}

QLabel#lblJudul {
    color:white;
    font-size:28px;
    font-weight:700;
}

QLabel#lblSub {
    color:#71767B;
    font-size:11pt;
}

QLabel {
    color:#E7E9EA;
}

QLineEdit,
QComboBox,
QSpinBox,
QDateEdit {
    background:#000000;
    border:1px solid #2F3336;
    border-radius:10px;
    padding:10px;
    color:white;
    min-height:20px;
}

QLineEdit:focus,
QComboBox:focus,
QSpinBox:focus,
QDateEdit:focus {
    border:2px solid #1D9BF0;
}

QPushButton {
    border:none;
    border-radius:16px;
    padding:12px;
    font-weight:700;
}

QPushButton#btnSimpan {
    background:#1D9BF0;
    color:white;
}

QPushButton#btnSimpan:hover {
    background:#1785D1;
}

QPushButton#btnUbah {
    background:#FFD400;
    color:black;
}

QPushButton#btnHapus {
    background:#F4212E;
    color:white;
}

QPushButton#btnBersihkan,
QPushButton#btnCari,
QPushButton#btnResetCari {
    background:#EFF3F4;
    color:black;
}

QTableWidget {
    background:#000000;
    border:1px solid #2F3336;
    border-radius:12px;
    gridline-color:#2F3336;
    color:white;
}

QHeaderView::section {
    background:#16181C;
    color:white;
    border:none;
    padding:10px;
    font-weight:700;
}

